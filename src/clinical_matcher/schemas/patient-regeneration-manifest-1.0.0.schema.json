{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Charlie-Uni/ClinicalMatcher/schemas/patient-regeneration-manifest-1.0.0.schema.json",
  "title": "Restricted patient regeneration aggregate manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "manifest_sha256",
    "source_dataset_id",
    "source_dataset_version",
    "access_policy",
    "terms_url",
    "adapter",
    "generated_at",
    "code_commit",
    "input_raw_sha256",
    "normalized_output_sha256",
    "patient_count",
    "modifications",
    "disclosure_note"
  ],
  "properties": {
    "manifest_version": {
      "const": "1.0.0"
    },
    "manifest_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "source_dataset_id": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "source_dataset_version": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "access_policy": {
      "enum": [
        "credentialed",
        "restricted"
      ]
    },
    "terms_url": {
      "type": "string",
      "format": "uri"
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "const": "normalized-json"
        },
        "version": {
          "const": "1.0.0"
        }
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "code_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "input_raw_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "normalized_output_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "patient_count": {
      "type": "integer",
      "minimum": 1
    },
    "modifications": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "disclosure_note": {
      "$ref": "#/$defs/nonEmptyString"
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
