{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Charlie-Uni/ClinicalMatcher/schemas/apixaban-staging-corpus-1.0.0.schema.json",
  "title": "Restricted MIMIC-IV-Ext Apixaban staging corpus",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apixaban_corpus_version",
    "source",
    "adapter",
    "patients"
  ],
  "properties": {
    "apixaban_corpus_version": {"const": "1.0.0"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dataset_id",
        "dataset_version",
        "access_policy",
        "license_id",
        "terms_url",
        "source_csv_sha256"
      ],
      "properties": {
        "dataset_id": {"const": "MIMIC-IV-Ext-Apixaban-Trial-Criteria-Questions"},
        "dataset_version": {"const": "1.0.0"},
        "access_policy": {"const": "credentialed"},
        "license_id": {"const": "PhysioNet Restricted Health Data License 1.5.0"},
        "terms_url": {"type": "string", "format": "uri"},
        "source_csv_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "pseudonymization",
        "evidence_chunk_max_characters"
      ],
      "properties": {
        "name": {"const": "mimic-iv-ext-apixaban-csv"},
        "version": {"const": "1.0.0"},
        "pseudonymization": {"const": "HMAC-SHA256"},
        "evidence_chunk_max_characters": {
          "type": "integer",
          "minimum": 256
        }
      }
    },
    "patients": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/patient"}
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "nonEmptyString": {"type": "string", "minLength": 1},
    "sourceSpan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": {"type": "integer", "minimum": 0},
        "end": {"type": "integer", "minimum": 1}
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_id", "source_id", "source_span", "text"],
      "properties": {
        "evidence_id": {
          "type": "string",
          "pattern": "^evidence-[0-9a-f]{24}-[0-9]{3,}$"
        },
        "source_id": {
          "type": "string",
          "pattern": "^note-[0-9a-f]{24}$"
        },
        "source_span": {"$ref": "#/$defs/sourceSpan"},
        "text": {"$ref": "#/$defs/nonEmptyString"}
      }
    },
    "legacyQuestion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "criterion_id",
        "source_criterion_label",
        "question_type",
        "question",
        "answer_status",
        "answer_value",
        "not_specified",
        "source_row_number"
      ],
      "properties": {
        "criterion_id": {
          "type": "string",
          "pattern": "^apixaban-q-[0-9a-f]{16}$"
        },
        "source_criterion_label": {"$ref": "#/$defs/nonEmptyString"},
        "question_type": {"enum": ["boolean", "numeric"]},
        "question": {"$ref": "#/$defs/nonEmptyString"},
        "answer_status": {
          "enum": ["answered", "not_specified", "source_anomaly"]
        },
        "answer_value": {
          "type": ["boolean", "number", "null"]
        },
        "not_specified": {"type": "boolean"},
        "source_row_number": {"type": "integer", "minimum": 2}
      }
    },
    "patient": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "patient_id",
        "source_id",
        "index_date",
        "index_date_status",
        "evidence",
        "legacy_questions"
      ],
      "properties": {
        "patient_id": {
          "type": "string",
          "pattern": "^patient-[0-9a-f]{24}$"
        },
        "source_id": {
          "type": "string",
          "pattern": "^note-[0-9a-f]{24}$"
        },
        "index_date": {"type": "null"},
        "index_date_status": {"const": "unavailable_in_source"},
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/evidence"}
        },
        "legacy_questions": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/legacyQuestion"}
        }
      }
    }
  }
}
