{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Charlie-Uni/ClinicalMatcher/schemas/apixaban-import-manifest-1.0.0.schema.json",
  "title": "Aggregate MIMIC-IV-Ext Apixaban import manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apixaban_import_manifest_version",
    "manifest_sha256",
    "generated_at",
    "code_commit",
    "source",
    "adapter",
    "pseudonymization",
    "outputs",
    "counts",
    "quality",
    "modifications",
    "disclosure_note"
  ],
  "properties": {
    "apixaban_import_manifest_version": {"const": "1.0.0"},
    "manifest_sha256": {"$ref": "#/$defs/sha256"},
    "generated_at": {"type": "string", "format": "date-time"},
    "code_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dataset_id",
        "dataset_version",
        "source_csv_sha256",
        "checksum_manifest_sha256",
        "license_sha256",
        "official_checksum_verified"
      ],
      "properties": {
        "dataset_id": {"const": "MIMIC-IV-Ext-Apixaban-Trial-Criteria-Questions"},
        "dataset_version": {"const": "1.0.0"},
        "source_csv_sha256": {"$ref": "#/$defs/sha256"},
        "checksum_manifest_sha256": {"$ref": "#/$defs/sha256"},
        "license_sha256": {"$ref": "#/$defs/sha256"},
        "official_checksum_verified": {"const": true}
      }
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "evidence_chunk_max_characters"
      ],
      "properties": {
        "name": {"const": "mimic-iv-ext-apixaban-csv"},
        "version": {"const": "1.0.0"},
        "evidence_chunk_max_characters": {
          "type": "integer",
          "minimum": 256
        }
      }
    },
    "pseudonymization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "key_id",
        "raw_ids_in_corpus",
        "raw_ids_in_separate_id_map"
      ],
      "properties": {
        "algorithm": {"const": "HMAC-SHA256"},
        "key_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._-]{1,64}$"
        },
        "raw_ids_in_corpus": {"const": false},
        "raw_ids_in_separate_id_map": {"const": true}
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["corpus_sha256", "id_map_sha256"],
      "properties": {
        "corpus_sha256": {"$ref": "#/$defs/sha256"},
        "id_map_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_row_count",
        "patient_count",
        "criterion_count",
        "evidence_chunk_count",
        "answered_label_count",
        "not_specified_label_count",
        "source_anomaly_label_count",
        "index_date_unavailable_patient_count"
      ],
      "properties": {
        "source_row_count": {"type": "integer", "minimum": 1},
        "patient_count": {"type": "integer", "minimum": 1},
        "criterion_count": {"type": "integer", "minimum": 1},
        "evidence_chunk_count": {"type": "integer", "minimum": 1},
        "answered_label_count": {"type": "integer", "minimum": 0},
        "not_specified_label_count": {"type": "integer", "minimum": 0},
        "source_anomaly_label_count": {"type": "integer", "minimum": 0},
        "index_date_unavailable_patient_count": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "complete_patient_criterion_grid",
        "runtime_patient_source_ready",
        "runtime_blocker"
      ],
      "properties": {
        "complete_patient_criterion_grid": {"type": "boolean"},
        "runtime_patient_source_ready": {"const": false},
        "runtime_blocker": {"$ref": "#/$defs/nonEmptyString"}
      }
    },
    "modifications": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/nonEmptyString"}
    },
    "disclosure_note": {"$ref": "#/$defs/nonEmptyString"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "nonEmptyString": {"type": "string", "minLength": 1}
  }
}
