{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Charlie-Uni/ClinicalMatcher/schemas/pilot-annotation-1.0.0.schema.json",
  "title": "Independent patient-trial pilot annotation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pilot_annotation_version",
    "pilot_id",
    "manifest_sha256",
    "annotation_manual_version",
    "annotator_id",
    "annotation_status",
    "independence_attestation",
    "units"
  ],
  "properties": {
    "pilot_annotation_version": {"const": "1.0.0"},
    "pilot_id": {"type": "string", "pattern": "^pilot-[A-Za-z0-9._-]+$"},
    "manifest_sha256": {"$ref": "#/$defs/sha256"},
    "annotation_manual_version": {"$ref": "#/$defs/nonEmptyString"},
    "annotator_id": {"$ref": "#/$defs/nonEmptyString"},
    "annotation_status": {"enum": ["draft", "completed"]},
    "independence_attestation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "peer_annotations_not_viewed",
        "model_outputs_not_viewed"
      ],
      "properties": {
        "peer_annotations_not_viewed": {"type": "boolean"},
        "model_outputs_not_viewed": {"type": "boolean"}
      }
    },
    "units": {
      "type": "array",
      "minItems": 2,
      "items": {"$ref": "#/$defs/unit"}
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "nonEmptyString": {"type": "string", "minLength": 1},
    "nullableString": {"type": ["string", "null"]},
    "decision": {"enum": ["eligible", "ineligible", "unknown", null]},
    "trialJudgment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "relevance_grade", "rationale"],
      "properties": {
        "decision": {"$ref": "#/$defs/decision"},
        "relevance_grade": {
          "type": ["integer", "null"],
          "minimum": 0,
          "maximum": 3
        },
        "rationale": {"$ref": "#/$defs/nullableString"}
      }
    },
    "criterionJudgment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "criterion_id",
        "decision",
        "evidence_ids",
        "rationale"
      ],
      "properties": {
        "criterion_id": {"$ref": "#/$defs/nonEmptyString"},
        "decision": {"$ref": "#/$defs/decision"},
        "evidence_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/nonEmptyString"}
        },
        "rationale": {"$ref": "#/$defs/nullableString"}
      }
    },
    "unit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unit_id",
        "active_minutes",
        "trial_judgment",
        "criterion_judgments"
      ],
      "properties": {
        "unit_id": {"type": "string", "pattern": "^pilot-unit-[A-Za-z0-9._-]+$"},
        "active_minutes": {"type": ["number", "null"], "exclusiveMinimum": 0},
        "trial_judgment": {"$ref": "#/$defs/trialJudgment"},
        "criterion_judgments": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/criterionJudgment"}
        }
      }
    }
  }
}
