{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Charlie-Uni/ClinicalMatcher/schemas/pilot-manifest-1.0.0.schema.json",
  "title": "Restricted local patient-trial annotation pilot manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pilot_manifest_version",
    "pilot_id",
    "manifest_sha256",
    "annotation_manual_version",
    "created_at",
    "code_commit",
    "source",
    "blinding",
    "annotator_ids",
    "units",
    "disclosure_note"
  ],
  "properties": {
    "pilot_manifest_version": {"const": "1.0.0"},
    "pilot_id": {"type": "string", "pattern": "^pilot-[A-Za-z0-9._-]+$"},
    "manifest_sha256": {"$ref": "#/$defs/sha256"},
    "annotation_manual_version": {"$ref": "#/$defs/nonEmptyString"},
    "created_at": {"type": "string", "format": "date-time"},
    "code_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "patient_source_id",
        "patient_source_sha256",
        "trial_source_id",
        "trial_source_sha256",
        "access_policy"
      ],
      "properties": {
        "patient_source_id": {"$ref": "#/$defs/nonEmptyString"},
        "patient_source_sha256": {"$ref": "#/$defs/sha256"},
        "trial_source_id": {"$ref": "#/$defs/nonEmptyString"},
        "trial_source_sha256": {"$ref": "#/$defs/sha256"},
        "access_policy": {"enum": ["synthetic", "restricted_local"]}
      }
    },
    "blinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_outputs_hidden",
        "peer_annotations_hidden"
      ],
      "properties": {
        "model_outputs_hidden": {"const": true},
        "peer_annotations_hidden": {"const": true}
      }
    },
    "annotator_ids": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/nonEmptyString"}
    },
    "units": {
      "type": "array",
      "minItems": 2,
      "items": {"$ref": "#/$defs/unit"}
    },
    "disclosure_note": {"$ref": "#/$defs/nonEmptyString"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "nonEmptyString": {"type": "string", "minLength": 1},
    "idArray": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/nonEmptyString"}
    },
    "unit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unit_id",
        "patient_id",
        "trial_id",
        "criterion_ids",
        "allowed_evidence_ids"
      ],
      "properties": {
        "unit_id": {"type": "string", "pattern": "^pilot-unit-[A-Za-z0-9._-]+$"},
        "patient_id": {"$ref": "#/$defs/nonEmptyString"},
        "trial_id": {"$ref": "#/$defs/nonEmptyString"},
        "criterion_ids": {"$ref": "#/$defs/idArray"},
        "allowed_evidence_ids": {"$ref": "#/$defs/idArray"}
      }
    }
  }
}
