{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Charlie-Uni/ClinicalMatcher/schemas/trial-snapshot-1.1.0.schema.json",
  "title": "Capacity-bound immutable ClinicalTrials.gov benchmark snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "snapshot_version",
    "snapshot_id",
    "snapshot_content_sha256",
    "registry",
    "attribution",
    "terms_url",
    "api_version",
    "api_data_timestamp",
    "created_at",
    "builder_code_commit",
    "selection",
    "search",
    "selection_audit_path",
    "selection_audit_sha256",
    "candidate_keys",
    "records",
    "coverage_report_path",
    "coverage_report_sha256"
  ],
  "properties": {
    "snapshot_version": {"const": "1.1.0"},
    "snapshot_id": {"type": "string", "pattern": "^ctg-[0-9a-f]{16}$"},
    "snapshot_content_sha256": {"$ref": "#/$defs/sha256"},
    "registry": {"const": "ClinicalTrials.gov"},
    "attribution": {"$ref": "#/$defs/nonEmptyString"},
    "terms_url": {
      "const": "https://clinicaltrials.gov/about-site/terms-conditions"
    },
    "api_version": {"$ref": "#/$defs/nonEmptyString"},
    "api_data_timestamp": {"$ref": "#/$defs/nonEmptyString"},
    "created_at": {"type": "string", "format": "date-time"},
    "builder_code_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "selection": {"$ref": "#/$defs/selection"},
    "search": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registry_reported_total_count",
        "fetched_candidate_count",
        "pages_fetched",
        "registry_fetch_complete"
      ],
      "properties": {
        "registry_reported_total_count": {"type": "integer", "minimum": 0},
        "fetched_candidate_count": {"type": "integer", "minimum": 0},
        "pages_fetched": {"type": "integer", "minimum": 1},
        "registry_fetch_complete": {"const": true}
      }
    },
    "selection_audit_path": {"const": "selection-audit.json"},
    "selection_audit_sha256": {"$ref": "#/$defs/sha256"},
    "candidate_keys": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/nonEmptyString"}
    },
    "records": {
      "type": "array",
      "minItems": 2,
      "items": {
        "oneOf": [
          {"$ref": "#/$defs/importedRecord"},
          {"$ref": "#/$defs/rejectedRecord"}
        ]
      }
    },
    "coverage_report_path": {"const": "coverage-report.json"},
    "coverage_report_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "nonEmptyString": {"type": "string", "minLength": 1},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "nctIdOrNull": {
      "type": ["string", "null"],
      "pattern": "^NCT[0-9]{8}$"
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "disease_domain",
        "rationale",
        "query_parameters",
        "filters",
        "sampling",
        "capacity_binding"
      ],
      "properties": {
        "disease_domain": {"$ref": "#/$defs/nonEmptyString"},
        "rationale": {"$ref": "#/$defs/nonEmptyString"},
        "query_parameters": {
          "type": "object",
          "minProperties": 6,
          "additionalProperties": {"type": "string"}
        },
        "filters": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "study_types",
            "overall_statuses",
            "require_eligibility_text",
            "first_posted_from",
            "first_posted_to"
          ],
          "properties": {
            "study_types": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {"$ref": "#/$defs/nonEmptyString"}
            },
            "overall_statuses": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {"$ref": "#/$defs/nonEmptyString"}
            },
            "require_eligibility_text": {"const": true},
            "first_posted_from": {"type": "string", "format": "date"},
            "first_posted_to": {"type": "string", "format": "date"}
          }
        },
        "sampling": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "method",
            "seed",
            "target_study_count",
            "registry_order_used_for_sampling"
          ],
          "properties": {
            "method": {"const": "sha256_seeded_nct_id_v1"},
            "seed": {"$ref": "#/$defs/nonEmptyString"},
            "target_study_count": {"type": "integer", "minimum": 2},
            "registry_order_used_for_sampling": {"const": false}
          }
        },
        "capacity_binding": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "capacity_plan_id",
            "capacity_plan_sha256",
            "target_patient_count",
            "target_patient_trial_units"
          ],
          "properties": {
            "capacity_plan_id": {
              "type": "string",
              "pattern": "^capacity-[0-9a-f]{16}$"
            },
            "capacity_plan_sha256": {"$ref": "#/$defs/sha256"},
            "target_patient_count": {"type": "integer", "minimum": 1},
            "target_patient_trial_units": {"type": "integer", "minimum": 2}
          }
        }
      }
    },
    "importedRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_key",
        "candidate_index",
        "nct_id",
        "source_study_path",
        "source_study_sha256",
        "status",
        "protocol_path",
        "protocol_sha256",
        "source_record_version",
        "registry_snapshot_date",
        "last_update_posted",
        "eligibility_sha256",
        "criterion_count",
        "criterion_ids"
      ],
      "properties": {
        "candidate_key": {"$ref": "#/$defs/nonEmptyString"},
        "candidate_index": {"type": "integer", "minimum": 0},
        "nct_id": {"type": "string", "pattern": "^NCT[0-9]{8}$"},
        "source_study_path": {"$ref": "#/$defs/nonEmptyString"},
        "source_study_sha256": {"$ref": "#/$defs/sha256"},
        "status": {"const": "imported"},
        "protocol_path": {"$ref": "#/$defs/nonEmptyString"},
        "protocol_sha256": {"$ref": "#/$defs/sha256"},
        "source_record_version": {"$ref": "#/$defs/nonEmptyString"},
        "registry_snapshot_date": {"type": "string", "format": "date"},
        "last_update_posted": {"type": "string", "format": "date"},
        "eligibility_sha256": {"$ref": "#/$defs/sha256"},
        "criterion_count": {"type": "integer", "minimum": 1},
        "criterion_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/nonEmptyString"}
        }
      }
    },
    "rejectedRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_key",
        "candidate_index",
        "nct_id",
        "source_study_path",
        "source_study_sha256",
        "status",
        "reason_code",
        "reason"
      ],
      "properties": {
        "candidate_key": {"$ref": "#/$defs/nonEmptyString"},
        "candidate_index": {"type": "integer", "minimum": 0},
        "nct_id": {"$ref": "#/$defs/nctIdOrNull"},
        "source_study_path": {"$ref": "#/$defs/nonEmptyString"},
        "source_study_sha256": {"$ref": "#/$defs/sha256"},
        "status": {"enum": ["skipped", "failed"]},
        "reason_code": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "reason": {"$ref": "#/$defs/nonEmptyString"}
      }
    }
  }
}
